# ---- OpenAI ----
# Required. Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-me

# ---- LLM defaults (used when PromptRequest leaves them empty) ----
# Low-cost default. Other options: gpt-4o-mini, gpt-4.1-mini, gpt-5-mini.
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ---- gRPC server ----
GRPC_PORT=50051

# ---- Logging ----
# INFO for production, DEBUG to log every streamed delta.
LOG_LEVEL=INFO
